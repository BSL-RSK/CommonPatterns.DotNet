## 🧪 Breakdown of Key Tests

### ✅ Constructor_ShouldThrow_WhenConnectionFactoryIsNull
```csharp
[Fact]
public void Constructor_ShouldThrow_WhenConnectionFactoryIsNull()
{
    Assert.Throws<ArgumentNullException>(() => new UserRepository(null!, Mock.Of<ILogger<UserRepository>>()));
}
```

---

### ✅ GetUsernames_ShouldReturnExpectedResults_WhenValid
```csharp
[Fact]
public void GetUsernames_ShouldReturnExpectedResults_WhenValid()
{
    _mockConnectionFactory.Setup(x => x.QueryNames()).Returns(["alice", "bob"]);

    var result = _sut.GetUsernames();

    Assert.Equal(["alice", "bob"], result);
}
```

---

### ❌ GetUsernames_ShouldReturnEmpty_WhenSourceReturnsNull
```csharp
[Fact]
public void GetUsernames_ShouldReturnEmpty_WhenSourceReturnsNull()
{
    _mockConnectionFactory.Setup(x => x.QueryNames()).Returns((IEnumerable<string>)null!);

    var result = _sut.GetUsernames();

    Assert.NotNull(result);
    Assert.Empty(result);
}
```

---

### 💥 GetUsernames_ShouldHandleDataException
```csharp
[Fact]
public void GetUsernames_ShouldHandleDataException()
{
    _mockConnectionFactory.Setup(x => x.QueryNames()).Throws(new InvalidOperationException());

    var ex = Assert.Throws<RepositoryException>(() => _sut.GetUsernames());
    Assert.Contains("failed to retrieve", ex.Message.ToLower());
}
```

---

### 🧾 GetUsernames_ShouldLogInfo_WhenRetrieved
```csharp
[Fact]
public void GetUsernames_ShouldLogInfo_WhenRetrieved()
{
    _mockConnectionFactory.Setup(x => x.QueryNames()).Returns(["charlie"]);

    _sut.GetUsernames();

    _mockLogger.Verify(
        x => x.Log(
            LogLevel.Information,
            It.IsAny<EventId>(),
            It.Is<It.IsAnyType>((v, t) => v.ToString()!.Contains("Usernames retrieved")),
            null,
            It.IsAny<Func<It.IsAnyType, Exception?, string>>()),
        Times.Once);
}
```

